# Copy to .env.local for local development
# cp .env.example .env.local

# Backend API URL (proxied by Vite dev server as /api → localhost:8000)
# For production, set to the full backend URL:
# VITE_API_URL=https://api.your-domain.com
VITE_API_URL=/api

# Dev-only: fake Telegram user when running outside Telegram
# Must match a user that exists or will be auto-created in the backend
VITE_DEV_USER={"id":1,"first_name":"Test"}
