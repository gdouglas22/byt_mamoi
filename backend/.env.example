# Copy this file to .env and fill in your values
# cp .env.example .env

# ── Required ───────────────────────────────────────────────────────────────
# Telegram Bot token from @BotFather
BOT_TOKEN=1234567890:ABCDefghIJKLmnopQRSTuvwxyz

# Public HTTPS URL where your Mini App frontend is hosted
# Must be HTTPS — Telegram requires it
MINI_APP_URL=https://your-miniapp.example.com

# ── Optional ───────────────────────────────────────────────────────────────
# Database URL (default: local SQLite file)
DATABASE_URL=sqlite+aiosqlite:///./byt_mamoi.db

# OTP link-code lifetime in seconds (default: 600 = 10 min)
OTP_TTL=600

# Set to True during local development to skip Telegram signature checks
# Authorization header should then be: tma {"id":123,"first_name":"Test"}
DEBUG=False

# Comma-separated CORS origins (Telegram's web origins are included by default)
# ALLOWED_ORIGINS=https://web.telegram.org,https://telegram.org
